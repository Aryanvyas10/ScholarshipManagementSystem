/* =========================
   RESPONSIVE
========================= */

@media(max-width:992px){

    .cards{
        grid-template-columns:
        repeat(2,1fr);
    }

    .navbar{
        padding:0 30px;
    }

    .hero-content h1{
        font-size:45px;
    }
}

@media(max-width:768px){

    .sidebar{
        width:80px;
    }

    .main{
        margin-left:80px;
    }

    .cards{
        grid-template-columns:1fr;
    }

    .footer-container{
        grid-template-columns:1fr;
    }

    .nav-links{
        display:none;
    }

    .hero-content h1{
        font-size:32px;
    }
}
